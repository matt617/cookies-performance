{
  "name": "cookies-performance",
  "tree": {
    "$className": "DataModel",
    "ServerScriptService": {
      "$path": "src/server"
    },
    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      }
    },
    "StarterPlayer": {
      "StarterPlayerScripts": {
        "$path": "src/client"
      }
    },
    "Workspace": {
      "$properties": {
        "FilteringEnabled": true,
        "StreamingEnabled": false
      }
    }
  }
}
